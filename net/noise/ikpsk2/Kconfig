# Noise IKpsk2 cryptographic framework configuration
#
config NOISE_IKPSK2
	tristate "Noise IKpsk2 cryptographic framework"
	depends on CRYPTO
	# Library interfaces for <crypto/curve25519.h> and
	# <crypto/chacha20poly1305.h>. BLAKE2s is always built-in, so there is
	# no Kconfig symbol to select for <crypto/blake2s.h>.
	select CRYPTO_LIB_CURVE25519
	select CRYPTO_LIB_CHACHA20POLY1305
	# Kernel keyring used to hold the Noise long-term secrets (PSKs and
	# static private keys), provisioned from userspace with keyctl(1).
	select KEYS
	default n
	help
	  Kernel-internal Noise IKpsk2 handshake and transport
	  encryption framework using Curve25519, ChaChaPoly, and BLAKE2s.

	  Provides handshake and symmetric encrypt/decrypt
	  symbols for use by other kernel subsystems.

	  If unsure, say N.
